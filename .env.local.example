# Template — copy to .env.local and fill in a real key.
# .env.local is gitignored; this file is safe to commit.

# Required. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx

# Model used by api/ai/chat.ts.
# ⚠️ KEEP THIS AS SONNET. Do NOT switch back to Opus — Sonnet 4.6 is 5×
# cheaper and is sufficient for medical Q&A in this app. Flip to Opus only
# for a specific one-off test, then flip it back before committing.
AI_MODEL=claude-sonnet-4-6
