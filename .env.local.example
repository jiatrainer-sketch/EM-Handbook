# Template — copy to .env.local and fill in a real key.
# .env.local is gitignored; this file is safe to commit.

# Required. Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxx

# Optional. Overrides the Claude model used by api/ai/chat.ts.
# Cheaper options: claude-haiku-4-5, claude-sonnet-4-6
AI_MODEL=claude-opus-4-7
